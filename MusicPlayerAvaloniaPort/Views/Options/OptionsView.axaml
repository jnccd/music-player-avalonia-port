<UserControl
    x:Class="MusicPlayerAvaloniaPort.Views.Options.OptionsView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:MusicPlayerAvaloniaPort.Converters;assembly=MusicPlayerAvaloniaPort"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:vm="using:MusicPlayerAvaloniaPort.ViewModels"
    x:DataType="vm:OptionsViewModel">
    <UserControl.Resources>
        <conv:AddMultiplyConverter x:Key="AddMultiplyConverter" />
        <conv:EitherOrConverter x:Key="EitherOrConverter" />
    </UserControl.Resources>
    <StackPanel>
        <TextBlock Text="This is the second window." />
    </StackPanel>
</UserControl>

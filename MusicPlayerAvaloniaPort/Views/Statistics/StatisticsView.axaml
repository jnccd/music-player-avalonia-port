<UserControl
x:Class="MusicPlayerAvaloniaPort.Views.Statistics.StatisticsView"
xmlns="https://github.com/avaloniaui"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:conv="clr-namespace:MusicPlayerAvaloniaPort.Converters;assembly=MusicPlayerAvaloniaPort"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
xmlns:sys="clr-namespace:System;assembly=mscorlib"
xmlns:vm="using:MusicPlayerAvaloniaPort.ViewModels"
x:DataType="vm:StatisticsViewModel">
    <UserControl.Resources>
        <conv:AddMultiplyConverter x:Key="AddMultiplyConverter" />
        <conv:EitherOrConverter x:Key="EitherOrConverter" />
    </UserControl.Resources>

    <DataGrid ItemsSource="{Binding StatisticsSongVMs}" IsReadOnly="True" CanUserResizeColumns="True" CanUserSortColumns="True">
        <DataGrid.Columns>
            <DataGridTextColumn Header="Name"  Binding="{Binding Name}"/>
            <DataGridTextColumn Header="Score" Binding="{Binding Score}" />
        </DataGrid.Columns>
    </DataGrid>

</UserControl>
